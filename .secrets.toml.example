# .secrets.toml — per-project secret manifest (NAMES ONLY, never values).
# Copy to `.secrets.toml` in your project root. Safe to commit: it lists which
# keys a project needs, not their contents. `secrets exec <project> -- <cmd>`
# does one Touch ID read, decrypts just these keys, injects them child-only
# into <cmd>'s environment, and zeroizes.
#
# Grant an agent access once (human runs it, Touch ID):
#   secrets authorize claude myapp                       # permanent
#   secrets authorize claude myapp --session-minutes 15  # timed

# ── Local vault backend (default) ─────────────────────────────────────────
[projects.myapp]
secrets = ["DATABASE_URL", "STRIPE_SECRET_KEY"]
# Usage: secrets exec myapp -- cargo run

# ── Google Secret Manager backend ─────────────────────────────────────────
# Values come live from GSM via gcloud, not the local vault. The active
# identity needs roles/secretmanager.secretAccessor (+ secretVersionAdder to write).
# [gsm]
# project = "my-gcp-project"
# secrets = ["DATABASE_URL", "API_KEY"]

# ── Generic external manager (AWS / Vault / Doppler / 1Password / …) ───────
# {name} is substituted per key; reads return the value on stdout, writes take
# it on stdin (never argv). See README §5b for verified recipes.
# [backend]
# kind    = "command"
# name    = "aws"
# secrets = ["DATABASE_URL", "API_KEY"]
# read    = ["aws", "secretsmanager", "get-secret-value", "--secret-id", "{name}", "--query", "SecretString", "--output", "text"]
# write   = ["aws", "secretsmanager", "put-secret-value", "--secret-id", "{name}", "--secret-string", "file:///dev/stdin"]
